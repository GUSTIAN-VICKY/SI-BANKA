        <!-- L2: Sistem -->
        <mxCell id="b0" value="canManageUsers()?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="L2">
